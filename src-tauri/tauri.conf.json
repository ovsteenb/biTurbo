{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "biTurbo",
  "version": "0.1.4",
  "identifier": "com.biturbo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "biTurbo — Memory Layer",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/biturbo-mcp"],
    "category": "DeveloperTool",
    "shortDescription": "Local-first memory layer for AI coding agents",
    "longDescription": "biTurbo gives your AI coding agents persistent, semantic, local-first memory. Built on turbovec for maximum compression. Includes an MCP server so any agent can read/write memories, projects, and indexed code.",
    "macOS": {
      "signingIdentity": "Developer ID Application: Abduellatif Yesil (89NFSUEFES)",
      "hardenedRuntime": true,
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxMjYxQzk4MDE5N0UxODEKUldTQjRaY0JtQndtOFRudDg1cklQY2dCMTlFbjlkTnhEdlgwOUd1dGc2N2tXS2JDWGIyc1h3TmkK",
      "endpoints": [
        "https://github.com/ltfysl/biTurbo/releases/latest/download/latest.json"
      ]
    }
  }
}
