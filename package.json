{
  "name": "biturbo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first memory layer for AI coding agents. turbovec + Tauri 2 + MCP.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:notarized": "APPLE_ID=\"$APPLE_ID\" APPLE_PASSWORD=\"$APPLE_PASSWORD\" APPLE_TEAM_ID=\"$APPLE_TEAM_ID\" tauri build",
    "mcp:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin biturbo-mcp",
    "mcp:build": "cargo build --manifest-path src-tauri/Cargo.toml --bin biturbo-mcp",
    "mcp:test": "node --experimental-strip-types --no-warnings scripts/mcp-smoke-test.ts",
    "recall:eval": "node --experimental-strip-types --no-warnings scripts/recall-eval.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.4.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=11.0.0"
  }
}
